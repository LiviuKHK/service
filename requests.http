# ==========================================
# CONFIG
# ==========================================
@baseUrl = http://localhost:8080

# TIP:
# În Codespaces, dacă nu merge localhost:
# copy URL din PORTS si înlocuiești aici o singură linie:
# @baseUrl = https://xxxxx-8080.app.github.dev


# ==========================================
# USER CONTROLLER
# ==========================================

### Get all users
GET {{baseUrl}}/api/users
#GET https://obscure-barnacle-r47p4rj9xxw5fxprq-8080.app.github.dev/api/users

### Create user
# @name createUser
POST {{baseUrl}}/api/users
Content-Type: application/json

{
    "name": "Jean Valjean",
    "email": "prisoner24601@france.fr"
}

### Get user by ID
GET {{baseUrl}}/api/users/{{createUser.response.body.id}}

### Get user by email
GET {{baseUrl}}/api/users/by-email?email={{createUser.response.body.email}}

### Update user (PUT)
PUT {{baseUrl}}/api/users/{{createUser.response.body.id}}
Content-Type: application/json

{
    "name": "Monsieur Madeleine"
}

### Change user name (PATCH)
PATCH {{baseUrl}}/api/users/{{createUser.response.body.id}}/name
Content-Type: application/json

{
    "name": "Monsieur le Maire"
}

### Delete user
DELETE {{baseUrl}}/api/users/{{createUser.response.body.id}}


# ==========================================
# TODO CONTROLLER
# ==========================================

### Create todo
# @name createTodo
POST {{baseUrl}}/api/todos
Content-Type: application/json

{
    "subject": "Study",
    "taskName": "Spring Boot",
    "description": "Learn REST APIs",
    "deadline": "2026-06-10",
    "assigneeEmail": "prisoner24601@france.fr"
}

### Get todos by email
GET {{baseUrl}}/api/todos?assigneeEmail={{createUser.response.body.email}}

### Get todo by ID
GET {{baseUrl}}/api/todos/{{createTodo.response.body.id}}

### Mark todo as done
PATCH {{baseUrl}}/api/todos/{{createTodo.response.body.id}}/done
Content-Type: application/json

true

### Assign todo
PATCH {{baseUrl}}/api/todos/{{createTodo.response.body.id}}/assignee
Content-Type: application/json

{
    "newAssigneeEmail": "prisoner24601@france.fr"
}

### Edit todo description
PATCH {{baseUrl}}/api/todos/{{createTodo.response.body.id}}/description
Content-Type: application/json

{
    "description": "Finish Spring Boot REST API project"
}

### Delete todo
DELETE {{baseUrl}}/api/todos/{{createTodo.response.body.id}}